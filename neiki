  echo -e "  ${GREEN}kill${NC}     <name>         Kill process by name"
  echo ""
  echo -e "${BOLD}DEPLOYMENT${NC}"
  echo -e "  ${GREEN}deploy${NC}   <src> <dest>   Deploy via rsync"
  echo ""
  echo -e "${BOLD}OTHER${NC}"
  echo -e "  ${GREEN}help${NC}                    Show this help"
  echo -e "  ${GREEN}version${NC}                 Show version"
  echo ""
}

cmd_version() {
  echo -e "${CYAN}${BOLD}neiki${NC} v${VERSION}"
}

# ============================================================================
# Main
# ============================================================================

main() {
  local command="${1:-help}"
  shift 2>/dev/null || true

  case "$command" in
    info)       cmd_info ;;
    clean)      cmd_clean ;;
    update)     cmd_update ;;
    ports)      cmd_ports ;;
    ip)         cmd_ip ;;
    scan)       cmd_scan "$@" ;;
    logs)       cmd_logs "$@" ;;
    watch)      cmd_watch "$@" ;;
    deploy)     cmd_deploy "$@" ;;
    restart)    cmd_restart "$@" ;;
    status)     cmd_status ;;
    uptime)     cmd_uptime ;;
    users)      cmd_users ;;
    disk)       cmd_disk ;;
    mem)        cmd_mem ;;
    services)   cmd_services ;;
    start)      cmd_start "$@" ;;
    stop)       cmd_stop "$@" ;;
    firewall)   cmd_firewall ;;
    open)       cmd_open "$@" ;;
    close)      cmd_close "$@" ;;
    whois)      cmd_whois "$@" ;;
    dns)        cmd_dns "$@" ;;
    curl)       cmd_curl "$@" ;;
    search)     cmd_search "$@" ;;
    extract)    cmd_extract "$@" ;;
    compress)   cmd_compress "$@" ;;
    temp)       cmd_temp ;;
    kill)       cmd_kill "$@" ;;
    top)        cmd_top ;;
    help|-h|--help) cmd_help ;;
    version|-v|--version) cmd_version ;;
    *)
      print_err "Unknown command: $command"
      echo -e "Run '${BOLD}$SCRIPT_NAME help${NC}' for usage."
      exit 1
      ;;
  esac
}

main "$@"
