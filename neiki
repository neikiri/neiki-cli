set -euo pipefail

VERSION="1.0.1"
SCRIPT_NAME="neiki"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
LIME='\033[38;2;204;255;0m'
NC='\033[0m'

# ============================================================================
# Helpers
# ============================================================================

print_header() {
  echo -e "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${CYAN}${BOLD}  $1${NC}"
  echo -e "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

print_section() {
  echo -e "\n${YELLOW}${BOLD}▸ $1${NC}"
}

print_ok() {
  echo -e "${GREEN}✔${NC} $1"
}

print_warn() {
  echo -e "${YELLOW}⚠${NC} $1"
}

print_err() {
  echo -e "${RED}✖${NC} $1" >&2
}

print_info() {
  echo -e "${BLUE}ℹ${NC} $1"
}

install_if_missing() {
  if ! command -v "$1" &> /dev/null; then
    echo -e "${YELLOW}Installing ${BOLD}$1${NC}${YELLOW}...${NC}"
    sudo apt install -y "$1"
  fi
}

require_root() {
  if [[ $EUID -ne 0 ]]; then
    print_err "This command requires root privileges. Use sudo."
    exit 1
  fi
}

# ============================================================================
# Commands
# ============================================================================

cmd_info() {
  print_header "System Information"

  echo -e "${BOLD}Hostname:${NC}      $(hostname)"
  echo -e "${BOLD}OS:${NC}            $(lsb_release -ds 2>/dev/null || cat /etc/os-release | grep PRETTY_NAME | cut -d= -f2 | tr -d '"')"
  echo -e "${BOLD}Kernel:${NC}        $(uname -r)"
  echo -e "${BOLD}Architecture:${NC}  $(uname -m)"
  echo -e "${BOLD}Uptime:${NC}        $(uptime -p)"
  echo -e "${BOLD}Shell:${NC}         $SHELL"
  echo -e "${BOLD}User:${NC}          $(whoami)"
  echo -e "${BOLD}CPU:${NC}           $(grep -m1 'model name' /proc/cpuinfo | cut -d: -f2 | xargs)"
  echo -e "${BOLD}CPU Cores:${NC}     $(nproc)"
  echo -e "${BOLD}Total RAM:${NC}     $(free -h | awk '/Mem:/ {print $2}')"
  echo -e "${BOLD}Disk Usage:${NC}    $(df -h / | awk 'NR==2 {print $3 "/" $2 " (" $5 " used)"}')"

  local ip_addr
  ip_addr=$(hostname -I 2>/dev/null | awk '{print $1}')
  echo -e "${BOLD}Local IP:${NC}      ${ip_addr:-N/A}"
}

cmd_clean() {
  print_header "System Cleanup"
  require_root

  print_section "Cleaning APT cache"
  apt autoremove -y
  apt autoclean -y

  print_section "Cleaning thumbnail cache"
  rm -rf ~/.cache/thumbnails/* 2>/dev/null || true

  print_section "Cleaning journal logs (older than 3 days)"
  journalctl --vacuum-time=3d 2>/dev/null || true

  print_section "Cleaning /tmp"
  find /tmp -type f -atime +7 -delete 2>/dev/null || true

  print_ok "Cleanup complete!"
}

cmd_update() {
  print_header "System Update"
  require_root

  print_section "Updating package lists"
  apt update

  print_section "Upgrading packages"
  apt upgrade -y

  print_section "Removing unused packages"
  apt autoremove -y

  print_ok "System updated successfully!"
}

cmd_ports() {
  print_header "Open Ports"
  install_if_missing net-tools

  echo -e "${BOLD}Proto  Local Address          PID/Program${NC}"
  echo "────────────────────────────────────────────────"
  ss -tulnp 2>/dev/null | tail -n +2 | awk '{printf "%-7s %-23s %s\n", $1, $5, $7}'
}

cmd_ip() {
  print_header "IP Address Information"

  print_section "Local IP"
  hostname -I | tr ' ' '\n' | grep -v '^$' | while read -r ip; do
    echo -e "  ${GREEN}$ip${NC}"
  done

  print_section "Public IP"
  local pub_ip
  pub_ip=$(curl -s --max-time 5 ifconfig.me 2>/dev/null || echo "N/A")
  echo -e "  ${GREEN}$pub_ip${NC}"

  print_section "Network Interfaces"
  ip -br addr show 2>/dev/null | while read -r line; do
    echo "  $line"
  done
}

cmd_scan() {
  print_header "Network Scan"
  install_if_missing nmap

  local target="${1:-}"
  if [[ -z "$target" ]]; then
    target=$(ip route | grep default | awk '{print $3}' | head -1)
    local subnet
    subnet=$(echo "$target" | sed 's/\.[0-9]*$/.0\/24/')
    target="$subnet"
  fi

  print_info "Scanning $target ..."
  nmap -sn "$target" 2>/dev/null | grep -E "Nmap scan|Host is|MAC Address"
}

cmd_logs() {
  print_header "System Logs"
  local lines="${1:-50}"

  print_section "Last $lines lines from syslog"
  if [[ -f /var/log/syslog ]]; then
    tail -n "$lines" /var/log/syslog
  else
    journalctl -n "$lines" --no-pager
  fi
}

cmd_watch() {
  print_header "Live Log Watcher"
  local logfile="${1:-}"

  if [[ -z "$logfile" ]]; then
    if [[ -f /var/log/syslog ]]; then
      logfile="/var/log/syslog"
    else
      print_info "Using journalctl for live logs"
      journalctl -f
      return
    fi
  fi

  if [[ ! -f "$logfile" ]]; then
    print_err "File not found: $logfile"
    exit 1
  fi

  print_info "Watching $logfile (Ctrl+C to stop)"
  tail -f "$logfile"
}

cmd_deploy() {
  print_header "Web Deploy"

  local source="${1:-}"
  local dest="${2:-}"

  if [[ -z "$source" || -z "$dest" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME deploy <source_dir> <user@host:/path>${NC}"
    echo ""
    echo "Examples:"
    echo "  $SCRIPT_NAME deploy ./dist user@server:/var/www/html"
    echo "  $SCRIPT_NAME deploy ./public root@192.168.1.10:/var/www/mysite"
    exit 1
  fi

  install_if_missing rsync

  print_info "Deploying $source → $dest"
  rsync -avz --progress --delete "$source" "$dest"
  print_ok "Deploy complete!"
}

cmd_restart() {
  print_header "Restart Service"
  require_root

  local service="${1:-}"
  if [[ -z "$service" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME restart <service_name>${NC}"
    echo ""
    echo "Examples:"
    echo "  $SCRIPT_NAME restart nginx"
    echo "  $SCRIPT_NAME restart apache2"
    exit 1
  fi

  print_info "Restarting $service..."
  systemctl restart "$service"
  systemctl status "$service" --no-pager -l
  print_ok "$service restarted successfully!"
}

cmd_status() {
  print_header "Quick System Status"

  print_section "CPU"
  local cpu_usage
  cpu_usage=$(top -bn1 | grep "Cpu(s)" | awk '{print $2}' | cut -d. -f1)
  local bar=""
  local filled=$((cpu_usage / 5))
  for ((i = 0; i < 20; i++)); do
    if ((i < filled)); then bar+="█"; else bar+="░"; fi
  done
  echo -e "  Usage: [${GREEN}${bar}${NC}] ${cpu_usage}%"
  echo -e "  Cores: $(nproc)"
  echo -e "  Load:  $(cat /proc/loadavg | awk '{print $1, $2, $3}')"

  print_section "Memory"
  local mem_info
  mem_info=$(free -m | awk '/Mem:/ {printf "%d %d %d", $2, $3, $3*100/$2}')
  local mem_total mem_used mem_pct
  mem_total=$(echo "$mem_info" | awk '{print $1}')
  mem_used=$(echo "$mem_info" | awk '{print $2}')
  mem_pct=$(echo "$mem_info" | awk '{print $3}')
  bar=""
  filled=$((mem_pct / 5))
  for ((i = 0; i < 20; i++)); do
    if ((i < filled)); then bar+="█"; else bar+="░"; fi
  done
  echo -e "  Usage: [${GREEN}${bar}${NC}] ${mem_pct}%"
  echo -e "  Used:  ${mem_used}M / ${mem_total}M"

  print_section "Disk (/)"
  local disk_pct
  disk_pct=$(df / | awk 'NR==2 {print $5}' | tr -d '%')
  bar=""
  filled=$((disk_pct / 5))
  for ((i = 0; i < 20; i++)); do
    if ((i < filled)); then bar+="█"; else bar+="░"; fi
  done
  echo -e "  Usage: [${GREEN}${bar}${NC}] ${disk_pct}%"
  echo -e "  $(df -h / | awk 'NR==2 {print "Used: " $3 " / " $2 "  Free: " $4}')"
}

cmd_uptime() {
  print_header "System Uptime"
  echo -e "${BOLD}Uptime:${NC}  $(uptime -p)"
  echo -e "${BOLD}Since:${NC}   $(uptime -s)"
  echo -e "${BOLD}Load:${NC}    $(cat /proc/loadavg | awk '{print $1, $2, $3}')"
}

cmd_users() {
  print_header "Logged-in Users"
  install_if_missing finger 2>/dev/null || true

  echo -e "${BOLD}USER       TTY      FROM             LOGIN@${NC}"
  echo "──────────────────────────────────────────────────"
  who | awk '{printf "%-10s %-8s %-16s %s %s\n", $1, $2, $5, $3, $4}'
  echo ""
  print_info "Total logged-in users: $(who | wc -l)"
}

cmd_disk() {
  print_header "Disk Usage"
  echo -e "${BOLD}Filesystem      Size  Used  Avail  Use%  Mounted on${NC}"
  echo "────────────────────────────────────────────────────────"
  df -h --output=source,size,used,avail,pcent,target -x tmpfs -x devtmpfs 2>/dev/null | tail -n +2 | while read -r line; do
    local pct
    pct=$(echo "$line" | awk '{print $5}' | tr -d '%')
    if ((pct > 90)); then
      echo -e "${RED}$line${NC}"
    elif ((pct > 70)); then
      echo -e "${YELLOW}$line${NC}"
    else
      echo "$line"
    fi
  done
}

cmd_mem() {
  print_header "Memory Usage"

  free -h | head -1 | awk '{printf "%-10s %8s %8s %8s %8s %8s\n", "", $1, $2, $3, $4, $5}'
  free -h | tail -n +2 | while read -r line; do
    echo "$line"
  done

  echo ""
  print_section "Top Memory Consumers"
  ps aux --sort=-%mem | head -11 | awk 'NR==1 {printf "%-8s %5s %5s  %s\n", "USER", "%MEM", "RSS", "COMMAND"} NR>1 {printf "%-8s %5s %5s  %s\n", $1, $4, $6, $11}'
}

cmd_services() {
  print_header "Running Services"
  systemctl list-units --type=service --state=running --no-pager --no-legend | awk '{printf "  %-40s %s\n", $1, $4}'
  echo ""
  print_info "Total running services: $(systemctl list-units --type=service --state=running --no-pager --no-legend | wc -l)"
}

cmd_start() {
  print_header "Start Service"
  require_root

  local service="${1:-}"
  if [[ -z "$service" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME start <service_name>${NC}"
    exit 1
  fi

  print_info "Starting $service..."
  systemctl start "$service"
  systemctl status "$service" --no-pager -l
  print_ok "$service started!"
}

cmd_stop() {
  print_header "Stop Service"
  require_root

  local service="${1:-}"
  if [[ -z "$service" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME stop <service_name>${NC}"
    exit 1
  fi

  print_info "Stopping $service..."
  systemctl stop "$service"
  print_ok "$service stopped!"
}

cmd_firewall() {
  print_header "Firewall Status"
  install_if_missing ufw

  sudo ufw status verbose
}

cmd_open() {
  print_header "Open Port"
  require_root
  install_if_missing ufw

  local port="${1:-}"
  if [[ -z "$port" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME open <port>${NC}"
    echo "  Example: $SCRIPT_NAME open 8080"
    echo "  Example: $SCRIPT_NAME open 443/tcp"
    exit 1
  fi

  ufw allow "$port"
  print_ok "Port $port opened!"
  ufw status | grep "$port"
}

cmd_close() {
  print_header "Close Port"
  require_root
  install_if_missing ufw

  local port="${1:-}"
  if [[ -z "$port" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME close <port>${NC}"
    exit 1
  fi

  ufw deny "$port"
  print_ok "Port $port closed!"
}

cmd_whois() {
  print_header "WHOIS Lookup"
  install_if_missing whois

  local domain="${1:-}"
  if [[ -z "$domain" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME whois <domain>${NC}"
    exit 1
  fi

  whois "$domain" | grep -iE "domain name|registrar|creation|expir|name server|status" | head -20
}

cmd_dns() {
  print_header "DNS Lookup"
  install_if_missing dnsutils

  local domain="${1:-}"
  if [[ -z "$domain" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME dns <domain>${NC}"
    exit 1
  fi

  print_section "A Records"
  dig +short A "$domain" 2>/dev/null || nslookup "$domain" | grep "Address"

  print_section "MX Records"
  dig +short MX "$domain" 2>/dev/null || true

  print_section "NS Records"
  dig +short NS "$domain" 2>/dev/null || true

  print_section "TXT Records"
  dig +short TXT "$domain" 2>/dev/null || true
}

cmd_curl() {
  print_header "HTTP Request"

  local url="${1:-}"
  if [[ -z "$url" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME curl <url>${NC}"
    exit 1
  fi

  install_if_missing curl

  print_section "Response Headers"
  curl -sI --max-time 10 "$url" 2>/dev/null | head -20

  print_section "Response Body (first 50 lines)"
  curl -s --max-time 10 "$url" 2>/dev/null | head -50
}

cmd_search() {
  print_header "File Search"

  local pattern="${1:-}"
  local path="${2:-.}"

  if [[ -z "$pattern" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME search <pattern> [path]${NC}"
    echo "  Example: $SCRIPT_NAME search 'TODO' ./src"
    echo "  Example: $SCRIPT_NAME search 'error' /var/log"
    exit 1
  fi

  print_info "Searching for '$pattern' in $path"
  grep -rn --color=always "$pattern" "$path" 2>/dev/null | head -100
  echo ""
  print_info "Results limited to 100 matches."
}

cmd_extract() {
  print_header "Extract Archive"

  local file="${1:-}"
  if [[ -z "$file" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME extract <archive>${NC}"
    echo "  Supported: .tar.gz .tar.bz2 .tar.xz .zip .rar .7z .gz .bz2"
    exit 1
  fi

  if [[ ! -f "$file" ]]; then
    print_err "File not found: $file"
    exit 1
  fi

  print_info "Extracting $file..."

  case "$file" in
    *.tar.gz|*.tgz)     tar -xzf "$file" ;;
    *.tar.bz2|*.tbz2)   tar -xjf "$file" ;;
    *.tar.xz|*.txz)     tar -xJf "$file" ;;
    *.tar)               tar -xf "$file" ;;
    *.zip)               install_if_missing unzip; unzip "$file" ;;
    *.rar)               install_if_missing unrar; unrar x "$file" ;;
    *.7z)                install_if_missing p7zip-full; 7z x "$file" ;;
    *.gz)                gunzip "$file" ;;
    *.bz2)               bunzip2 "$file" ;;
    *.xz)                unxz "$file" ;;
    *)                   print_err "Unsupported format: $file"; exit 1 ;;
  esac

  print_ok "Extracted successfully!"
}

cmd_compress() {
  print_header "Compress Files"

  local output="${1:-}"
  shift 2>/dev/null || true
  local files=("$@")

  if [[ -z "$output" || ${#files[@]} -eq 0 ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME compress <output_file> <files...>${NC}"
    echo "  Example: $SCRIPT_NAME compress backup.tar.gz ./src ./docs"
    echo "  Example: $SCRIPT_NAME compress archive.zip file1 file2"
    exit 1
  fi

  print_info "Compressing to $output..."

  case "$output" in
    *.tar.gz|*.tgz)     tar -czf "$output" "${files[@]}" ;;
    *.tar.bz2|*.tbz2)   tar -cjf "$output" "${files[@]}" ;;
    *.tar.xz|*.txz)     tar -cJf "$output" "${files[@]}" ;;
    *.tar)               tar -cf "$output" "${files[@]}" ;;
    *.zip)               install_if_missing zip; zip -r "$output" "${files[@]}" ;;
    *.7z)                install_if_missing p7zip-full; 7z a "$output" "${files[@]}" ;;
    *)                   tar -czf "$output" "${files[@]}" ;;
  esac

  print_ok "Compressed to $output ($(du -h "$output" | awk '{print $1}'))"
}

cmd_temp() {
  print_header "Clean Temp Files"

  print_section "Cleaning /tmp"
  local count
  count=$(find /tmp -type f -atime +3 2>/dev/null | wc -l)
  find /tmp -type f -atime +3 -delete 2>/dev/null || true
  echo -e "  Removed ${GREEN}$count${NC} files older than 3 days"

  print_section "Cleaning user cache"
  local cache_size
  cache_size=$(du -sh ~/.cache 2>/dev/null | awk '{print $1}')
  echo -e "  Cache size: ${YELLOW}$cache_size${NC}"

  print_section "Cleaning trash"
  if [[ -d ~/.local/share/Trash ]]; then
    local trash_size
    trash_size=$(du -sh ~/.local/share/Trash 2>/dev/null | awk '{print $1}')
    rm -rf ~/.local/share/Trash/files/* 2>/dev/null || true
    rm -rf ~/.local/share/Trash/info/* 2>/dev/null || true
    echo -e "  Emptied trash (was ${YELLOW}$trash_size${NC})"
  else
    echo "  Trash is empty"
  fi

  print_ok "Temp cleanup complete!"
}

cmd_kill() {
  print_header "Kill Process"

  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo -e "Usage: ${BOLD}$SCRIPT_NAME kill <process_name>${NC}"
    exit 1
  fi

  local pids
  pids=$(pgrep -f "$name" 2>/dev/null || true)

  if [[ -z "$pids" ]]; then
    print_warn "No process found matching '$name'"
    exit 0
  fi

  echo -e "Found processes matching '${BOLD}$name${NC}':"
  ps aux | grep -v grep | grep "$name" | awk '{printf "  PID %-8s %5s%%  %s\n", $2, $3, $11}'
  echo ""

  read -rp "Kill all matching processes? [y/N] " confirm
  if [[ "$confirm" =~ ^[Yy]$ ]]; then
    pkill -f "$name"
    print_ok "Killed processes matching '$name'"
  else
    print_info "Aborted."
  fi
}

cmd_top() {
  print_header "Process Overview"

  print_section "Top CPU Consumers"
  echo -e "${DIM}  PID      CPU%   MEM%   USER       COMMAND${NC}"
  echo "  ─────────────────────────────────────────────────"
  ps aux --sort=-%cpu | head -11 | tail -10 | awk '{printf "  %-8s %5s  %5s  %-10s %s\n", $2, $3, $4, $1, $11}'

  print_section "Top Memory Consumers"
  echo -e "${DIM}  PID      MEM%   RSS(KB)  USER       COMMAND${NC}"
  echo "  ─────────────────────────────────────────────────"
  ps aux --sort=-%mem | head -11 | tail -10 | awk '{printf "  %-8s %5s  %7s  %-10s %s\n", $2, $4, $6, $1, $11}'

  echo ""
  print_info "Total processes: $(ps aux | wc -l)"
}

